# Meraki Dashboard API (required for MCP and optional backup script)
MERAKI_API_KEY=

# Optional: default org for discovery prompts
MERAKI_ORG_ID=

# Meraki Magic MCP: block write operations until you approve maintenance (recommended: true)
READ_ONLY_MODE=true

# Optional: used by tools/meraki_backup_network.py
BACKUP_NETWORK_ID=
